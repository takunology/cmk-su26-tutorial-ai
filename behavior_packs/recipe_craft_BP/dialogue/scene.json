{
  "format_version": "1.17",
  "minecraft:npc_dialogue": {
    "scenes": [
      {
        "scene_tag": "rc_intro",
        "npc_name": "エージェント",
        "text": "私も手伝いたいけど、何をすればいいか教えてください",
        "buttons": [
          {
            "name": "まずは見ててね",
            "commands": [
              "/scoreboard players set .stage global 1",
              "/tellraw @initiator {\"rawtext\":[{\"text\":\"木のつるはしを作って、手に持ってエージェントに見せよう。\"}]}"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_teach_wood",
        "npc_name": "エージェント",
        "text": "わたしにもおしえてください",
        "buttons": [
          {
            "name": "わかった！",
            "commands": [
              "/scoreboard players set .stage global 3",
              "/execute as @initiator run codebuilder navigate @s true https://minecraft.makecode.com/#tutorial:github:takunology/cmk-su26-tutorial-ai/tutorials/wood-pickaxe"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_learned_wood",
        "npc_name": "エージェント",
        "text": "おぼえました！木のつるはしをつくります",
        "buttons": [
          {
            "name": "つくって！",
            "commands": [
              "/function rc_agent_make_wood"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_next_furnace",
        "npc_name": "エージェント",
        "text": "つぎはなにをしますか",
        "buttons": [
          {
            "name": "かまどをつくる",
            "commands": [
              "/scoreboard players set .stage global 5",
              "/tellraw @initiator {\"rawtext\":[{\"text\":\"丸石でかまどを作って、手に持ってエージェントに見せよう。\"}]}"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_teach_furnace",
        "npc_name": "エージェント",
        "text": "かまどのつくりかたおしえてください",
        "buttons": [
          {
            "name": "いいよ！",
            "commands": [
              "/scoreboard players set .stage global 6",
              "/execute as @initiator run codebuilder navigate @s true https://minecraft.makecode.com/#tutorial:github:takunology/cmk-su26-tutorial-ai/tutorials/furnace"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_learned_furnace",
        "npc_name": "エージェント",
        "text": "おぼえました！かまどをつくります",
        "buttons": [
          {
            "name": "つくって！",
            "commands": [
              "/function rc_agent_make_furnace"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_prompt_ready",
        "npc_name": "エージェント",
        "text": "最後に、ここまでの作業をまとめたプロンプトを組んでみましょう",
        "buttons": [
          {
            "name": "プロンプトを組む",
            "commands": [
              "/scoreboard players set .stage global 8",
              "/execute as @initiator run codebuilder navigate @s true https://minecraft.makecode.com/#tutorial:github:takunology/cmk-su26-tutorial-ai/tutorials/agent-prompt"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_prompt_confirm",
        "npc_name": "エージェント",
        "text": "かまどを作るところまで作業しますか？",
        "buttons": [
          {
            "name": "はい",
            "commands": [
              "/function rc_prompt_run_all"
            ]
          }
        ]
      },
      {
        "scene_tag": "rc_prompt_success",
        "npc_name": "エージェント",
        "text": "ただしくプロンプトを組めましたね！",
        "buttons": [
          {
            "name": "おしまい",
            "commands": [
              "/scoreboard players set .stage global 10"
            ]
          }
        ]
      }
    ]
  }
}
